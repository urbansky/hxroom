# API-URL (wird vom Browser aufgerufen)
# Lokal ohne Caddy:
NUXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NUXT_PUBLIC_AUTH_URL=http://localhost:3000
NUXT_PUBLIC_ROOT_DOMAIN=hxroom.de
# Landingpage-Vorschau per HTTPS (Standard: true). Auf false setzen für lokale HTTP-Subdomains.
NUXT_PUBLIC_ROOT_DOMAIN_HTTPS=true
# Lokal mit Caddy (*.hxroom.localhost), stattdessen:
# NUXT_PUBLIC_API_URL=http://api.hxroom.localhost/api/v1
# NUXT_PUBLIC_AUTH_URL=http://api.hxroom.localhost
