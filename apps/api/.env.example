# Datenbank
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=hxroom
POSTGRES_USER=hxroom
POSTGRES_PASSWORD=hxroom

# better-auth
# Geheimschlüssel für Session-Signierung (min. 32 Zeichen)
# Generieren: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# CORS – kommagetrennte Allowed Origins
# Lokal ohne Caddy:
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
# Lokal mit Caddy (*.hxroom.localhost), stattdessen:
# CORS_ORIGINS=http://app.hxroom.localhost,http://admin.hxroom.localhost

# Coach-App URL (wird für E-Mail-Verifikations-Callback benötigt)
# Lokal ohne Caddy:
COACH_APP_URL=http://localhost:5173
# Lokal mit Caddy:
# COACH_APP_URL=http://app.hxroom.localhost

# Brevo – Transaktionsmails (POST /smtp/email)
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=noreply@hxroom.de
BREVO_SENDER_NAME=HxRoom
