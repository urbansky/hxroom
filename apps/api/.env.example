# Datenbank
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=hxroom
POSTGRES_USER=hxroom
POSTGRES_PASSWORD=hxroom

# better-auth
# Geheimschlüssel für Session-Signierung (min. 32 Zeichen)
# Generieren: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# CORS – kommagetrennte Allowed Origins (leer lässt nur localhost:517x zu)
CORS_ORIGINS=

# Brevo – Transaktionsmails (POST /smtp/email)
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=noreply@hxroom.de
BREVO_SENDER_NAME=HxRoom
