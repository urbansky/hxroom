# HxRoom – Infrastruktur Umgebungsvariablen
#
# Kopiere diese Datei nach `infra/.env` und trage die echten Werte ein.
# docker compose lädt `.env` im selben Verzeichnis wie die compose-Datei automatisch.
#
# Nicht einchecken: `.env` steht in .gitignore. Nur diese Beispiel-Datei ist versioniert.

# -----------------------------------------------------------------------------
# Caddy – TLS via Ionos DNS-01 Challenge
# -----------------------------------------------------------------------------
# Wird von Caddy (caddy-dns/ionos) genutzt, um Wildcard-Zertifikate für
# *.hxroom.de per DNS-01 Challenge bei Let's Encrypt zu erzeugen.
# Token erzeugen: https://developer.hosting.ionos.de/ → DNS API → neuen Token anlegen.
# Berechtigung: Zonen-Schreibzugriff auf hxroom.de.
IONOS_API_TOKEN=

# -----------------------------------------------------------------------------
# PostgreSQL – Datenbank
# -----------------------------------------------------------------------------
# Zugangsdaten für den postgres-Container und das API.
# Das API setzt die Connection-URL intern aus diesen Variablen zusammen.
# Passwort generieren: openssl rand -base64 32
# POSTGRES_HOST muss den Docker-Service-Namen verwenden (internes Netz).
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hxroom
POSTGRES_USER=hxroom
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# better-auth – Authentifizierung
# -----------------------------------------------------------------------------
# Geheimschlüssel für Session-Signierung. Mindestens 32 Zeichen.
# Generieren: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Basis-URL der API (ohne trailing slash). better-auth-Routen laufen unter /api/auth/*.
# Produktion: https://api.hxroom.de
# Entwicklung: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
