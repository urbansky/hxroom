{
	email admin@hxroom.de
}

(ionos-tls) {
	tls {
		dns ionos {env.IONOS_API_TOKEN}
	}
}

www.hxroom.de {
	import ionos-tls
	redir https://hxroom.de{uri} permanent
}

hxroom.de {
	import ionos-tls
	reverse_proxy landing:80
}

